# Database
DATABASE_URL=postgresql://user:password@localhost:5432/roster

# OpenRouter (for LLM roast generation)
OPENROUTER_API_KEY=sk-or-v1-...
NEXT_PUBLIC_BASE_URL=http://localhost:3005

# X API (for post syncing)
X_BEARER_TOKEN=

# NextAuth (for admin authentication)
NEXTAUTH_URL=http://localhost:3005
NEXTAUTH_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
ADMIN_EMAIL_ALLOWLIST=admin@example.com

# Cost limits (optional)
DAILY_X_CREDIT_BUDGET=1000
DAILY_OPENAI_TOKEN_BUDGET=100000
