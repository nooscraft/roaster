# Database
# For local: use a single URL for both
DATABASE_URL=postgresql://user:password@localhost:5432/roster
DIRECT_URL=postgresql://user:password@localhost:5432/roster

# For Neon (production): use pooled URL for app, direct for migrations
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# DIRECT_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# OpenRouter (for LLM roast generation)
OPENROUTER_API_KEY=sk-or-v1-...
NEXT_PUBLIC_BASE_URL=http://localhost:3005

# X API (for post syncing)
X_BEARER_TOKEN=

# NextAuth (for admin authentication)
NEXTAUTH_URL=http://localhost:3005
NEXTAUTH_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
ADMIN_EMAIL_ALLOWLIST=admin@example.com

# Cost limits (optional)
DAILY_X_CREDIT_BUDGET=1000
DAILY_OPENAI_TOKEN_BUDGET=100000

# Google Analytics (optional)
# Get your Measurement ID from https://analytics.google.com (Admin → Data Streams)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
