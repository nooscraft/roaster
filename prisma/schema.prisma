generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SourceType {
  X_HANDLE
}

enum RoastStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReportReason {
  HARASSMENT
  INACCURATE
  TOO_PERSONAL
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

enum OptOutMatchType {
  HANDLE
  URL_PREFIX
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Source {
  id        String     @id @default(cuid())
  type      SourceType @default(X_HANDLE)
  handle    String     @unique
  xUserId   String?
  enabled   Boolean    @default(true)
  lastSyncedAt DateTime?
  sinceId   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  posts     Post[]

  @@index([enabled])
  @@index([handle])
}

model Post {
  id            String   @id @default(cuid())
  sourceId      String
  externalId    String
  url           String
  publishedAt   DateTime
  textExcerpt   String   @db.Text
  lang          String?
  publicMetrics Json?
  rawHash       String
  ingestedAt    DateTime @default(now())
  source        Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  roast         Roast?

  @@unique([sourceId, externalId])
  @@index([sourceId])
  @@index([rawHash])
  @@index([publishedAt])
}

model Roast {
  id              String      @id @default(cuid())
  postId          String      @unique
  status          RoastStatus @default(PENDING)
  bubbleScore     Float
  archetype       String
  tags            String[]
  sections        Json
  promptVersionId String
  shareImageUrl   String?
  createdAt       DateTime    @default(now())
  approvedAt      DateTime?
  rejectedAt      DateTime?
  post            Post        @relation(fields: [postId], references: [id], onDelete: Cascade)
  promptVersion   PromptVersion @relation(fields: [promptVersionId], references: [id])
  reports         Report[]

  @@index([status])
  @@index([bubbleScore])
  @@index([createdAt])
  @@index([approvedAt])
}

model PromptVersion {
  id                  String   @id @default(cuid())
  name                String   @unique
  systemPrompt        String   @db.Text
  userPromptTemplate  String   @db.Text
  jsonSchema          Json
  isActive            Boolean  @default(false)
  createdAt           DateTime @default(now())
  roasts              Roast[]

  @@index([isActive])
}

model Report {
  id         String       @id @default(cuid())
  roastId    String
  reason     ReportReason
  details    String?      @db.Text
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  reviewedAt DateTime?
  roast      Roast        @relation(fields: [roastId], references: [id], onDelete: Cascade)

  @@index([roastId])
  @@index([status])
  @@index([createdAt])
}

model OptOut {
  id        String           @id @default(cuid())
  matchType OptOutMatchType
  value     String           @unique
  createdAt DateTime         @default(now())

  @@index([matchType])
}

model Badge {
  id            String   @id @default(cuid())
  handle        String
  bubbleScore   Float
  roastText     String   @db.Text
  bioText       String?  @db.Text
  tweetSamples  Json
  createdAt     DateTime @default(now())

  @@index([handle])
  @@index([createdAt])
}
